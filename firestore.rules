rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isDashboardOwner() {
      return request.auth != null
        && request.auth.token.email in [
          "luispaulo.carraro@gmail.com",
          "camiliaimperico@gmail.com"
        ];
    }

    match /householdDashboards/{dashboardId}/{document=**} {
      allow read, write: if isDashboardOwner();
    }
  }
}
